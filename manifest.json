<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>PixelPulse | Web Gaming</title>
    <link rel="stylesheet" href="style.css">
</head>
<body>
    <nav>
        <h1>PixelPulse</h1>
        <ul>
            <li>Home</li>
            <li>Top Rated</li>
            <li>New Releases</li>
        </ul>
    </nav>

    <main id="game-container">
        <div class="game-card" onclick="startGame('dodger')">
            <div class="thumbnail">🟦</div>
            <div class="info">
                <h3>Square Dodger</h3>
                <p>Avoid the red blocks!</p>
                <button>Play Now</button>
            </div>
        </div>
        </main>

    <div id="game-modal" class="hidden">
        <button id="close-btn" onclick="closeGame()">× Close</button>
        <canvas id="gameCanvas"></canvas>
    </div>

    <script src="script.js"></script>
</body>
</html>body {
    background: #121212;
    color: white;
    font-family: 'Segoe UI', sans-serif;
    margin: 0;
}

nav {
    display: flex;
    justify-content: space-between;
    padding: 1rem 5%;
    background: #1f1f1f;
    border-bottom: 2px solid #333;
}

#game-container {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 20px;
    padding: 40px 5%;
}

.game-card {
    background: #1f1f1f;
    border-radius: 12px;
    overflow: hidden;
    transition: transform 0.3s;
    cursor: pointer;
}

.game-card:hover {
    transform: translateY(-5px);
    border: 1px solid #00ff88;
}

.thumbnail {
    height: 150px;
    background: #333;
    display: flex;
    justify-content: center;
    align-items: center;
    font-size: 3rem;
}

.info { padding: 15px; }

/* Game Overlay */
#game-modal {
    position: fixed;
    top: 0; left: 0;
    width: 100%; height: 100%;
    background: rgba(0,0,0,0.9);
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
}

.hidden { display: none !important; }

canvas {
    background: #000;
    border: 4px solid #fff;
}const modal = document.getElementById('game-modal');
const canvas = document.getElementById('gameCanvas');
const ctx = canvas.getContext('2d');

canvas.width = 600;
canvas.height = 400;

let gameActive = false;
let player = { x: 50, y: 200, size: 20 };
let obstacles = [];

function startGame(gameId) {
    modal.classList.remove('hidden');
    gameActive = true;
    requestAnimationFrame(gameLoop);
}

function closeGame() {
    modal.classList.add('hidden');
    gameActive = false;
}

function gameLoop() {
    if (!gameActive) return;

    // 1. Clear Canvas
    ctx.clearRect(0, 0, canvas.width, canvas.height);

    // 2. Draw Player
    ctx.fillStyle = "#00ff88";
    ctx.fillRect(player.x, player.y, player.size, player.size);

    // 3. Simple Logic (Movement can be added with event listeners)
    // Add logic here for scoring or obstacle movement
    
    requestAnimationFrame(gameLoop);
}

// Basic movement
window.addEventListener('keydown', (e) => {
    if(e.key === "ArrowUp") player.y -= 10;
    if(e.key === "ArrowDown") player.y += 10;
});
