body {
    background: #121212;
    color: white;
    font-family: 'Segoe UI', sans-serif;
    margin: 0;
}

nav {
    display: flex;
    justify-content: space-between;
    padding: 1rem 5%;
    background: #1f1f1f;
    border-bottom: 2px solid #333;
}

#game-container {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 20px;
    padding: 40px 5%;
}

.game-card {
    background: #1f1f1f;
    border-radius: 12px;
    padding: 15px;
    border: 1px solid #333;
    text-align: center;
}

.hidden { display: none; }

canvas {
    background: #000;
    border: 2px solid #00ff88;
    display: block;
    margin: 20px auto;
}
